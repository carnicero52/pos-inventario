generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                String   @id @default("default")
  nombre            String
  nit               String?
  direccion         String?
  telefono          String?
  email             String?
  logoUrl           String?
  moneda            String   @default("DOP")
  simboloMoneda     String   @default("RD$")
  mensajeTicket     String?
  impresoraTicket   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Sucursal {
  id          String   @id @default(uuid())
  nombre      String
  direccion   String?
  telefono    String?
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  productos   ProductoSucursal[]
  ventas      Venta[]
  gastos      Gasto[]
}

model Categoria {
  id          String     @id @default(uuid())
  nombre      String     @unique
  descripcion String?
  color       String?
  activa      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  productos   Producto[]
}

model Proveedor {
  id          String   @id @default(uuid())
  nombre      String
  contacto    String?
  documento   String?  @unique
  email       String?
  telefono    String?
  direccion   String?
  notas       String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  productos   Producto[]
  compras     Compra[]
}

model Producto {
  id              String     @id @default(uuid())
  codigo          String     @unique
  codigoBarras    String?    @unique
  nombre          String
  descripcion     String?
  imagenUrl       String?
  
  categoriaId     String?
  categoria       Categoria? @relation(fields: [categoriaId], references: [id])
  
  proveedorId     String?
  proveedor       Proveedor? @relation(fields: [proveedorId], references: [id])
  
  costo           Float      @default(0)
  precioVenta     Float      @default(0)
  margenGanancia  Float      @default(0)
  
  tieneItbis      Boolean    @default(true)
  porcentajeItbis Float      @default(18)
  
  activo          Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  sucursales      ProductoSucursal[]
  detallesVenta   DetalleVenta[]
  detallesCompra  DetalleCompra[]
}

model ProductoSucursal {
  id          String   @id @default(uuid())
  productoId  String
  producto    Producto @relation(fields: [productoId], references: [id])
  sucursalId  String
  sucursal    Sucursal @relation(fields: [sucursalId], references: [id])
  stock       Int      @default(0)
  stockMinimo Int      @default(5)
  
  @@unique([productoId, sucursalId])
}

model Cliente {
  id            String   @id @default(uuid())
  nombre        String
  apellido      String?
  documento     String?  @unique
  email         String?
  telefono      String?
  direccion     String?
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  ventas        Venta[]
}

model Usuario {
  id          String   @id @default(uuid())
  nombre      String
  usuario     String   @unique
  password    String
  rol         String   @default("vendedor")
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  ventas      Venta[]
  gastos      Gasto[]
}

model Venta {
  id              String        @id @default(uuid())
  numeroFactura   String        @unique
  clienteId       String?
  cliente         Cliente?      @relation(fields: [clienteId], references: [id])
  usuarioId       String
  usuario         Usuario       @relation(fields: [usuarioId], references: [id])
  sucursalId      String
  sucursal        Sucursal      @relation(fields: [sucursalId], references: [id])
  
  subtotal        Float         @default(0)
  itbis           Float         @default(0)
  descuento       Float         @default(0)
  total           Float         @default(0)
  
  metodoPago      String        @default("efectivo")
  montoRecibido   Float?
  cambio          Float?
  
  estado          String        @default("completada")
  ncf             String?
  
  notas           String?
  fecha           DateTime      @default(now())
  createdAt       DateTime      @default(now())
  
  fechaAnulacion  DateTime?
  motivoAnulacion String?
  
  detalles        DetalleVenta[]
  
  @@index([fecha])
}

model DetalleVenta {
  id            String   @id @default(uuid())
  ventaId       String
  venta         Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  
  productoId    String
  producto      Producto @relation(fields: [productoId], references: [id])
  
  nombreManual  String?
  cantidad      Int
  precioUnitario Float
  costoUnitario Float   @default(0)
  subtotal      Float
  ganancia      Float   @default(0)
  
  createdAt     DateTime @default(now())
  
  @@index([ventaId])
}

model Compra {
  id              String         @id @default(uuid())
  numeroCompra    String         @unique
  proveedorId     String?
  proveedor       Proveedor?     @relation(fields: [proveedorId], references: [id])
  sucursalId      String?
  subtotal        Float          @default(0)
  itbis           Float          @default(0)
  total           Float          @default(0)
  estado          String         @default("recibida")
  numeroFactura   String?
  fechaFactura    DateTime?
  notas           String?
  fecha           DateTime       @default(now())
  createdAt       DateTime       @default(now())
  
  detalles        DetalleCompra[]
  
  @@index([fecha])
}

model DetalleCompra {
  id            String   @id @default(uuid())
  compraId      String
  compra        Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  productoId    String
  producto      Producto @relation(fields: [productoId], references: [id])
  cantidad      Int
  costoUnitario Float
  subtotal      Float
  createdAt     DateTime @default(now())
  
  @@index([compraId])
}

model Gasto {
  id          String   @id @default(uuid())
  concepto    String
  monto       Float
  categoria   String   @default("operativo")
  sucursalId  String?
  sucursal    Sucursal? @relation(fields: [sucursalId], references: [id])
  usuarioId   String?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  notas       String?
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())
  
  @@index([fecha])
}
